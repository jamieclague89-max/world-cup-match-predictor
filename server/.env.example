# World Cup Predictor — Server Environment Variables
# Copy this file to .env and fill in your values

# ── Supabase (required for leaderboard, predictions, results) ─────────────────
# Get these from: supabase.com → your project → Settings → API
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-secret-key-here

# ── Automated Results Sync ─────────────────────────────────────────────────────
# Get a free API key at https://www.football-data.org/
# Free tier: 10 requests/minute — more than enough for 5-minute polling
FOOTBALL_DATA_API_KEY=your_token_here

# ── Admin Access ───────────────────────────────────────────────────────────────
# Password required to access the admin panel and write results manually
# Change this to something secure before sharing the app
ADMIN_KEY=wc2026admin
